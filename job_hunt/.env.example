# Copy this file to .env and fill in the keys for your chosen provider.
# .env is gitignored — never commit it.

# ── Scraping (required) ───────────────────────────────────────────────────────
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LLM provider (set ONE of these) ──────────────────────────────────────────

# Option A: Anthropic / Claude  →  https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option B: Groq (free tier — Llama 3.3 70B)  →  https://console.groq.com
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option C: Google Gemini (free tier — Flash)  →  https://aistudio.google.com
# GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Override provider / model at runtime (optional) ──────────────────────────
# These take priority over config.yaml llm.provider / llm.model
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.3-70b-versatile
